{
  "Logger": {
    "Template": {
      "File": "[{Timestamp:yyyy/MM/dd HH:mm:ss.fff}] | {Level} | {SourceContext}{Scope} {MapName} {NewLine}{Message:lj}{NewLine}{Exception}{NewLine}",
      "Console": "[{Timestamp:MM/dd HH:mm:ss}] | {Level} | {SourceContext}{Scope} {MapName} {NewLine}{Message:lj}{NewLine}{Exception}{NewLine}"
    },
    "LogLevel": {
      "Default": "Verbose",
      "Microsoft": "Information",
      "System.Net.Http": "Warning"
    }
  },
  "ChatCommand.TriggerPrefixes": {
    "Public": [
      "!",
      "."
    ],
    "Silent": [
      "/",
      "`"
    ]
  },
"MenuManager": {
    "KeyBindings": {
      "MoveUpCursor": {
        // MenuBindingType enum: Command=0, Button=1
        // Type accepts enum name (case-insensitive) or numeric enum value.
        "Type": 0,
        // The command must be the ones that can be listened by the server, it does not have to be built-in commands like "autobuy"
        // Known commands that can't be listened by the server:
        // "slot0" to "slot13"
        // "cancelselect"
        "Command": "autobuy"
      },
      "MoveDownCursor": {
        "Type": 0,
        "Command": "rebuy"
      },
      "GoBack": {
        "Type": 1,
        // Button enum: Sharp.Shared.Enums.UserCommandButtons
        // see: https://github.com/Kxnrl/modsharp-public/blob/master/Sharp.Shared/Enums/UserCommandButtons.cs
        // Button accepts enum name (case-insensitive) or numeric enum value.
        "Button": "Speed"
      },
      "Confirm": {
        "Type": 1,
        "Button": "LookAtWeapon"
      },
      "Exit": {
        "Type": 1,
        "Button": "Scoreboard"
      }
    },
    "Colors": {
      // The game supports the following format:
      // #RGB, #RGBA, #RRGGBB, #RRGGBBAA
      // if you miss the '#' at the beginning, menu manager will add it for you, but we strongly recommend you to add it to prefix
      "Key": "#DDAA11",
      "Text": "#ffffff",
      "Disabled": "#888888",
      "Cursor": "#3399FF"
    }
  },
  "ConnectionStrings": {
    "ClientPreferences": "litedb://Filename={sharp::data}/client-preferences.db;Mode=Exclusive;Flush=true",
    "AdminCommands.SQLStorage": "mysql://Server=localhost;Port=3306;Database=modsharp;User ID=your_user_name_goes_here;Password=your_password_goes_here;"
  }
}